{
  "name": "@life-cockpit/angular-ui-kit",
  "version": "2.0.1",
  "description": "Life Cockpit Design System - Angular UI component library",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Life-Cockpit/lc-design-system.git"
  },
  "keywords": ["angular", "design-system", "angular-ui-kit", "components", "life-cockpit"],
  "peerDependencies": {
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "mermaid": "^11.0.0",
    "rxjs": "^7.8.0"
  },
  "peerDependenciesMeta": {
    "mermaid": {
      "optional": true
    }
  },
  "sideEffects": ["**/*.css", "**/*.scss"],
  "exports": {
    ".": {
      "types": "./types/life-cockpit-angular-ui-kit.d.ts",
      "default": "./fesm2022/life-cockpit-angular-ui-kit.mjs"
    },
    "./styles/*": {
      "default": "./src/styles/*"
    },
    "./package.json": {
      "default": "./package.json"
    }
  }
}
